{
  "name": "changelog-previous-tag",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/github": "9.0.0",
    "@renovatebot/pep440": "4.2.2",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/semver": "7.7.1",
    "esbuild": "0.25.12",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm run build"
  },
  "lint-staged": {
    "*.{ts,js,json,yaml,yml,md}": "prettier --write",
    "*.ts": "tsc --noEmit --skipLibCheck"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks"
    ]
  }
}
