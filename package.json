{
  "name": "changelog-previous-tag",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@renovatebot/pep440": "^4.0.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.8",
    "esbuild": "^0.25.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "simple-git-hooks": "^2.0.0",
    "typescript": "^5.8.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm run build"
  },
  "lint-staged": {
    "*.{ts,js,json,yaml,yml,md}": "prettier --write",
    "*.ts": "tsc --noEmit --skipLibCheck"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks"
    ]
  }
}
